# -----------------------------------------------------------------------------
# XM/Exness Ready Linux MetaTrader 5 API — Environment Example
# Author: Essa Mamdani
# -----------------------------------------------------------------------------

# REST API port (host side)
API_PORT=8000

# Mandatory header auth token. All /api/* routes require:
#   Authorization: Bearer <API_TOKEN>
API_TOKEN=change-me-to-a-strong-secret-token

# VNC access. Set VNC_ENABLED=true if you want VNC/noVNC ports exposed.
# Use docker-compose.vnc.yml to actually publish the ports.
VNC_ENABLED=true
VNC_PASSWORD=password
VNC_PORT=5901
NOVNC_PORT=6901

# Virtual screen resolution
SCREEN_RESOLUTION=1024x768
